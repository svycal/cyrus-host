#!/usr/bin/env bash
# git credential helper that serves a freshly-minted GitHub App installation
# token. git invokes this on every authenticated github.com operation (clone,
# fetch, push), so a mint-on-demand helper means the token is never stale — no
# refresh daemon required. `gh-app-token` caches briefly, so the back-to-back
# calls git makes within one operation don't each hit the API.
#
# Only `get` is handled; `store`/`erase` are no-ops (there's nothing to persist —
# the token is derived from the App key each time).
set -euo pipefail
[ "${1:-}" = "get" ] || exit 0
token="$(gh-app-token token)"
printf 'username=x-access-token\npassword=%s\n' "$token"
